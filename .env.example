# Clinical Documentation App — environment variables
# Copy this file to `.env` (which is gitignored) and fill in the values below.
# Generate keys with:
#   python -c "import secrets; print(secrets.token_hex(32))"

# User-facing API key the desktop app uses to authenticate to the activation
# service. May be a single value or a comma-separated list of accepted keys.
CLINICAL_API_KEY=

# Admin key for /api/set_activation and /admin/* endpoints. Keep this private.
CLINICAL_ADMIN_KEY=

# Optional: enable Flask debug mode for the activation service (DO NOT use in
# production — exposes an interactive debugger). Default is off.
# FLASK_DEBUG=0

# Optional: route the desktop app's logs to a file (PHI-safe — only exception
# types are logged, never message text or file paths). Defaults to stderr.
# CLINICAL_LOG_FILE=C:\Users\you\AppData\Local\ClinicalSOAP\app.log

# Optional: override MySQL credentials without writing them to db_config.json.
# Useful in deployments where the file must be world-readable but secrets
# should not be. Any set value wins over the file's value.
# CLINICAL_DB_HOST=localhost
# CLINICAL_DB_PORT=3306
# CLINICAL_DB_USER=clinical_user
# CLINICAL_DB_PASSWORD=<your-mysql-password>
# CLINICAL_DB_NAME=clinical_docs
